# Neon Postgres (https://neon.tech — Free Tier reicht)
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# Tokenzählung für Quellen-Limits: entweder Anthropic exakt oder OpenRouter geschätzt
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash
OPENROUTER_RESEARCH_MODEL=perplexity/sonar-deep-research

# OpenAI (Whisper-Audiotranskription und bevorzugtes TTS für Audio Overview)
OPENAI_API_KEY=
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE_A=alloy
OPENAI_TTS_VOICE_B=onyx

# transcriptapi.com (primäre YouTube-Transkript-Quelle — umgeht YouTubes
# Anti-Bot-Sperre gegen Cloud-/Serverless-IPs; ohne Key greift automatisch
# die kostenlose Innertube-Fallback-Kette)
TRANSCRIPT_API_KEY=

# Vercel Blob (Datei-Uploads — im Vercel-Dashboard einen Blob-Store anlegen
# und den Token hierher kopieren; lokal nötig, auf Vercel selbst automatisch gesetzt)
BLOB_READ_WRITE_TOKEN=

# ElevenLabs (optional — Fallback, falls OpenAI-TTS nicht gesetzt ist)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_A=
ELEVENLABS_VOICE_B=
ELEVENLABS_MODEL=eleven_multilingual_v2

# Limits (optional — Defaults siehe src/lib/limits.ts)
# LIMIT_NOTEBOOKS_PER_VISITOR=5
# LIMIT_SOURCES_PER_NOTEBOOK=8
# LIMIT_TOKENS_PER_NOTEBOOK=100000
# LIMIT_CHAT_PER_VISITOR_DAY=30
# LIMIT_ARTIFACTS_PER_VISITOR_DAY=10
# LIMIT_AUDIO_PER_VISITOR_DAY=2
# LIMIT_RESEARCH_PER_VISITOR_DAY=3
# LIMIT_AUDIO_GLOBAL_DAY=10
# DAILY_BUDGET_CENTS=0
